${color1}${membar 10}${color}

${color1}${font Ubuntu:bold:size=14}DISK ${hr 1}${font}${color}
${color2}Root $alignc ${fs_used /} / ${fs_size /} $alignr ${fs_used_perc /}%
${color1}${fs_bar 10 /}${color}

${color1}${font Ubuntu:bold:size=14}TOP PROCESSES ${hr 1}${font}${color}
${font Ubuntu:size=11}${color2}NAME ${alignr}PID   CPU%   MEM%
${color white}${top name 1} ${alignr}${top pid 1} ${top cpu 1}% ${top mem 1}%
${top name 2} ${alignr}${top pid 2} ${top cpu 2}% ${top mem 2}%
