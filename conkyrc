
conky.config = {
    -- Window Settings
    own_window = true,
    own_window_type = 'desktop',
    own_window_transparent = false,
    own_window_argb_visual = true,
    own_window_argb_value = 240,
    own_window_colour = '#121212',
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',

    -- Padding & Borders
    border_inner_margin = 20,
    border_outer_margin = 0,

    -- Positioning (Targeting the far right of the right-most monitor)
    alignment = 'top_right',
    xinerama_head = 2,    -- 0 is Left, 1 is Center, 2 is Right [cite: 2026-02-28]
    gap_x = 50,           -- Increased distance from the right edge
    gap_y = 60,
    minimum_width = 450,  -- Widened slightly for larger fonts
    minimum_height = 1800,

    -- Graphics & Colors
    double_buffer = true,
    draw_shades = false,
    draw_outline = false,
    draw_borders = false,
    draw_graph_borders = true,
    default_color = '#FFFFFF',
    color1 = '#5af78e',
    color2 = '#f3f3f3',

    -- Text Settings
    use_xft = true,
    font = 'Ubuntu:size=12', -- Increased base font size
    update_interval = 2,
    cpu_avg_samples = 2,
    net_avg_samples = 2,
    uppercase = false,
};

conky.text = [[
${color1}${font Ubuntu:bold:size=30}${time %H:%M}${font}${alignr}${voffset -45}${color1}${time %A}${color}
${voffset 2}${alignr}${font Ubuntu:size=14}${color1}${time %d %b %Y}${font}${color}
${voffset 5}${hr 2}
${color1}${font Ubuntu:bold:size=14}SYSTEM ${hr 1}${font}${color}
${color2}Kernel:$alignr$kernel
Uptime:$alignr$uptime
Processes:$alignr$processes ($running_processes running)${color}

${color1}${font Ubuntu:bold:size=14}CPU ${hr 1}${font}${color}
${font Ubuntu:size=11}${color2}${execi 1000 grep model /proc/cpuinfo | cut -d : -f2 | tail -1 | sed 's/\s//'}$alignr${color1}${execi 5 sensors | grep 'Package id 0' | awk '{print $4}' | cut -c2-5}${font}${color}
${voffset 5}${color1}${cpugraph 45,450 333333 5af78e}${color}

${color1}${font Ubuntu:bold:size=14}GPU ${hr 1}${font}${color}
${color2}Model:$alignr${execi 60 nvidia-smi --query-gpu=name --format=csv,noheader,nounits}
Temp:$alignr${execi 5 nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits}°C
VRAM Usage:$alignr${execi 5 nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits}MB / ${execi 60 nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits}MB
${color1}${execibar 5 nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits}${color}

${font FreeMono:bold:size=11}${voffset 5}${color2}
